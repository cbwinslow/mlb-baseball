# -------------------------------------------------------
# MLB Baseball Analytics Platform — Environment Variables
# -------------------------------------------------------
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# PostgreSQL connection string (REQUIRED for db/ingest/validate commands)
DATABASE_URL=postgresql+psycopg://baseball:baseball@localhost:5432/baseball

# Root directory where downloaded raw data files are stored
DATA_DIR=/data/baseball

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# MLB StatsAPI base URL (default below is correct for public API)
MLB_API_BASE_URL=https://statsapi.mlb.com/api/v1

# Optional: override Retrosheet download URL
# RETROSHEET_BASE_URL=https://www.retrosheet.org/events

# Optional: Statcast / pybaseball settings
# STATCAST_WORKERS=4
